---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Sterling & Associates Attorneys — Johannesburg's premier law firm. Excellence. Integrity. Results. Serving South Africa's leading corporations and individuals since 1987." />
  <meta name="robots" content="index, follow" />
  <meta name="google-site-verification" content="zVRHVf9JET-P1gXxZBhJPIlUnFi_CnfbG8mgs4Qe4Gs" />
  <title>Sterling & Associates Attorneys | Sandton, Johannesburg</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body style="background:#0A0A0A;">

<!-- Fixed left editorial line -->
<div id="editorial-line" style="
  position:fixed;left:0;top:0;bottom:0;width:2px;
  background:linear-gradient(to bottom,transparent,rgba(201,151,43,0.2),transparent);
  z-index:100;pointer-events:none;
"></div>


<!-- ═══════════════════════════════════════════════
     NAVIGATION
═══════════════════════════════════════════════ -->
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 px-8 lg:px-16 py-5 border-b border-transparent">
  <div class="max-w-screen-xl mx-auto flex items-center justify-between">
    <a href="#home" class="flex flex-col leading-none no-underline">
      <span class="font-playfair text-2xl font-bold tracking-widest" style="color:var(--gold);line-height:1;">
        STERLING<span class="font-playfair italic font-normal text-lg opacity-70" style="color:var(--gold-light);">&nbsp;&amp;&nbsp;</span>
      </span>
      <span class="font-inter text-white text-[0.52rem] font-medium uppercase" style="letter-spacing:0.3em;">ASSOCIATES</span>
    </a>
    <div class="hidden lg:flex items-center gap-10">
      <a href="#practice" class="nav-link">Practice Areas</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#team" class="nav-link">Team</a>
      <a href="#results" class="nav-link">Results</a>
      <a href="#contact" class="nav-link">Contact</a>
      <a href="#contact" class="btn-outline" style="padding:0.7rem 1.4rem;font-size:0.58rem;">Book Consultation</a>
    </div>
    <button id="menu-toggle" class="lg:hidden flex flex-col gap-1.5 p-2 z-50 relative" aria-label="Open menu">
      <span class="block w-6 h-px transition-all duration-300" style="background:var(--gold)"></span>
      <span class="block w-6 h-px transition-all duration-300" style="background:var(--gold)"></span>
      <span class="block w-4 h-px transition-all duration-300 self-end" style="background:var(--gold)"></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 flex flex-col items-center justify-center" style="background:#050505;">
  <button id="menu-close" class="absolute top-6 right-6 p-2 text-2xl" style="color:var(--gold);" aria-label="Close">✕</button>
  <nav class="flex flex-col items-center gap-8">
    <a href="#practice" class="mobile-nav-link font-playfair text-4xl text-white hover:text-yellow-400 transition-colors duration-300">Practice Areas</a>
    <a href="#about"    class="mobile-nav-link font-playfair text-4xl text-white hover:text-yellow-400 transition-colors duration-300">About</a>
    <a href="#team"     class="mobile-nav-link font-playfair text-4xl text-white hover:text-yellow-400 transition-colors duration-300">Team</a>
    <a href="#results"  class="mobile-nav-link font-playfair text-4xl text-white hover:text-yellow-400 transition-colors duration-300">Results</a>
    <a href="#contact"  class="mobile-nav-link font-playfair text-4xl text-white hover:text-yellow-400 transition-colors duration-300">Contact</a>
    <a href="#contact" class="btn-gold mt-4">Book Consultation</a>
  </nav>
</div>


<!-- ═══════════════════════════════════════════════
     HERO — SPLIT DIAGONAL
═══════════════════════════════════════════════ -->
<section id="home" class="relative min-h-screen overflow-hidden" style="background:#0A0A0A;">
  <canvas id="particle-canvas" class="absolute inset-0 pointer-events-none" style="z-index:1;"></canvas>

  <!-- Diagonal clip right panel -->
  <div class="hero-right-panel" style="
    position:absolute;top:0;right:0;
    width:42%;height:100%;
    background:#141414;
    clip-path:polygon(12% 0,100% 0,100% 100%,0% 100%);
    border-left:none;z-index:2;
  ">
    <!-- Gold corner accents -->
    <div style="position:absolute;top:10%;right:8%;width:32px;height:32px;border-top:1px solid var(--gold);border-right:1px solid var(--gold);"></div>
    <div style="position:absolute;top:10%;right:calc(8% + 32px + 40%);width:32px;height:32px;border-top:1px solid var(--gold);border-left:1px solid var(--gold);opacity:.4;"></div>
    <div style="position:absolute;bottom:14%;right:8%;width:32px;height:32px;border-bottom:1px solid var(--gold);border-right:1px solid var(--gold);"></div>
    <div style="position:absolute;bottom:14%;right:calc(8% + 32px + 40%);width:32px;height:32px;border-bottom:1px solid var(--gold);border-left:1px solid var(--gold);opacity:.4;"></div>
    <!-- Firm image -->
    <picture class="absolute inset-0 w-full h-full">
      <source srcset="/images/firm-office.webp" type="image/webp" />
      <img
        src="/images/firm-office.jpg"
        alt="Sterling & Associates reception — Sandton, Johannesburg"
        loading="eager"
        decoding="async"
        style="width:100%;height:100%;object-fit:cover;object-position:center center;display:block;"
      />
    </picture>
    <!-- Subtle dark vignette overlay so text/accents read cleanly -->
    <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(10,10,10,0.35) 0%,transparent 60%);pointer-events:none;"></div>
    <!-- Subtle gold right border line on panel -->
    <div style="position:absolute;top:10%;right:6%;bottom:10%;width:1px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);opacity:0.3;"></div>
  </div>

  <!-- Left text block -->
  <div class="relative flex flex-col justify-center min-h-screen pl-8 lg:pl-20 pr-8 lg:pr-0" style="max-width:62%;z-index:3;padding-top:6rem;padding-bottom:8rem;">
    <p class="section-label mb-6 fade-up">Established 1987</p>
    <div class="mb-8 fade-up delay-1" style="width:60px;height:1px;background:var(--gold);"></div>
    <h1 class="font-playfair fade-up delay-1" style="line-height:1.08;">
      <span class="block text-white" style="font-size:clamp(2.8rem,6vw,5.2rem);font-weight:700;">When the Stakes</span>
      <span class="block font-playfair italic" style="font-size:clamp(3rem,7vw,5.8rem);font-weight:600;color:var(--gold);">Are Highest</span>
    </h1>
    <p class="font-inter mt-7 mb-10 fade-up delay-2" style="color:#AAAAAA;font-size:1rem;line-height:1.85;max-width:480px;font-weight:300;">
      Sterling &amp; Associates has represented South Africa's most discerning individuals and corporations for over three decades. Trusted. Precise. Uncompromising.
    </p>
    <div class="flex flex-wrap gap-4 fade-up delay-3">
      <a href="#contact" class="btn-gold">Request Consultation</a>
      <a href="#practice" class="btn-outline">Our Practice Areas</a>
    </div>
  </div>

  <!-- Stats strip pinned to bottom, full width -->
  <div class="absolute bottom-0 left-0 right-0 z-10 fade-up delay-4" style="border-top:1px solid var(--gold);background:rgba(10,10,10,0.95);backdrop-filter:blur(8px);">
    <div class="max-w-screen-xl mx-auto flex flex-col sm:flex-row items-center justify-center sm:justify-around py-5 px-8 gap-6 sm:gap-0">
      <div class="text-center">
        <div class="font-playfair text-4xl font-bold counter" data-target="37" style="color:var(--gold);">0</div>
        <div class="font-inter text-xs tracking-widest uppercase mt-1" style="color:#888;">Years</div>
      </div>
      <div class="stat-divider hidden sm:block"></div>
      <div class="text-center">
        <div class="font-playfair text-4xl font-bold" style="color:var(--gold);">1,200+</div>
        <div class="font-inter text-xs tracking-widest uppercase mt-1" style="color:#888;">Cases</div>
      </div>
      <div class="stat-divider hidden sm:block"></div>
      <div class="text-center">
        <div class="font-playfair text-4xl font-bold counter" data-target="98" data-suffix="%" style="color:var(--gold);">0</div>
        <div class="font-inter text-xs tracking-widest uppercase mt-1" style="color:#888;">Success Rate</div>
      </div>
      <div class="stat-divider hidden sm:block"></div>
      <div class="text-center">
        <div class="font-playfair text-4xl font-bold" style="color:var(--gold);">R12B+</div>
        <div class="font-inter text-xs tracking-widest uppercase mt-1" style="color:#888;">Assets Protected</div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     GOLD BAR
═══════════════════════════════════════════════ -->
<div style="background:var(--gold);padding:1.15rem 2rem;text-align:center;">
  <p class="font-inter font-semibold text-black tracking-[0.25em] uppercase" style="font-size:0.62rem;">
    Proudly Serving Johannesburg's Leading Corporations and Individuals Since 1987
  </p>
</div>


<!-- ═══════════════════════════════════════════════
     ABOUT — TYPOGRAPHIC / NEWSPAPER
═══════════════════════════════════════════════ -->
<section id="about" style="background:var(--bg-secondary);padding:6rem 2rem 0;">
  <div class="max-w-screen-xl mx-auto">
    <span class="section-label fade-up">About the Firm</span>

    <!-- Massive heading -->
    <h2 class="font-playfair text-white fade-up delay-1" style="
      font-size:clamp(2.6rem,7vw,4.8rem);
      font-weight:800;
      line-height:1.08;
      margin-top:1rem;
      margin-bottom:2.5rem;
      max-width:100%;
    ">
      Three Decades<br/>
      of Trusted<br/>
      <span class="font-playfair italic" style="color:var(--gold);">Legal Excellence</span>
    </h2>
    <span class="gold-underline fade-up delay-1" style="margin-left:0;margin-bottom:3rem;"></span>

    <!-- Newspaper two-column body -->
    <div class="newspaper-cols fade-up delay-2" style="
      column-count:2;
      column-gap:3.5rem;
      column-rule:1px solid var(--border-subtle);
      color:#BBBBBB;
      font-size:0.95rem;
      line-height:1.9;
      font-weight:300;
      max-width:900px;
      margin-bottom:4rem;
      font-family:'Inter',sans-serif;
    ">
      <p style="margin-bottom:1.2rem;">
        Sterling &amp; Associates was founded in 1987 by Senior Partner Jonathan Sterling, a Rhodes Scholar and former judge's clerk who believed that South Africa's corporate elite deserved legal representation without compromise.
      </p>
      <p style="margin-bottom:1.2rem;">
        From our founding offices in the heart of Sandton, we have grown to become one of Johannesburg's most respected law firms — trusted by JSE-listed companies, multinational corporations, high-net-worth individuals and family offices across Southern Africa.
      </p>
      <p>
        Our reputation is built not on volume but on precision. We accept only the cases we can win and give every client the full weight of our collective expertise.
      </p>
    </div>
  </div>

  <!-- Stats ticker bar — full width dark -->
  <div style="background:#0D0D0D;border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
    <div class="max-w-screen-xl mx-auto fade-up delay-3">
      <div class="flex flex-col sm:flex-row items-stretch">
        <div class="flex-1 text-center py-8 px-6" style="border-right:1px solid var(--gold);opacity:.4; border-right-opacity:1;">
          <div class="font-playfair text-3xl font-bold" style="color:var(--gold);">37 Years</div>
          <div class="font-inter text-xs tracking-widest uppercase mt-2" style="color:#666;">Serving Johannesburg</div>
        </div>
        <div class="flex-1 text-center py-8 px-6" style="border-right:1px solid rgba(201,151,43,0.3);">
          <div class="font-playfair text-3xl font-bold" style="color:var(--gold);">R12 Billion+</div>
          <div class="font-inter text-xs tracking-widest uppercase mt-2" style="color:#666;">In Client Assets Protected</div>
        </div>
        <div class="flex-1 text-center py-8 px-6" style="border-right:1px solid rgba(201,151,43,0.3);">
          <div class="font-playfair text-3xl font-bold" style="color:var(--gold);">1,200+</div>
          <div class="font-inter text-xs tracking-widest uppercase mt-2" style="color:#666;">Cases Handled</div>
        </div>
        <div class="flex-1 text-center py-8 px-6">
          <div class="font-playfair text-3xl font-bold" style="color:var(--gold);">98%</div>
          <div class="font-inter text-xs tracking-widest uppercase mt-2" style="color:#666;">Success Rate</div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     PRACTICE AREAS — ACCORDION
═══════════════════════════════════════════════ -->
<section id="practice" style="background:var(--bg-primary);padding:6rem 2rem;">
  <div class="max-w-screen-xl mx-auto">
    <div class="text-center mb-14">
      <span class="section-label fade-up">Practice Areas</span>
      <h2 class="font-playfair text-white fade-up delay-1" style="font-size:clamp(2rem,4vw,3rem);font-weight:700;line-height:1.2;">
        Comprehensive Legal Excellence
      </h2>
      <span class="gold-underline fade-up delay-1"></span>
      <p class="font-inter mt-6 mx-auto fade-up delay-2" style="color:#888;font-size:0.9rem;line-height:1.8;max-width:560px;font-weight:300;">
        Our attorneys bring decades of specialist expertise across South Africa's most complex and high-value legal matters.
      </p>
    </div>

    <!-- Accordion list -->
    <div id="accordion" class="fade-up delay-2">
      {[
        {
          num:'I',
          title:'Corporate & Commercial Law',
          body:'Mergers and acquisitions, corporate restructuring, shareholder agreements and commercial contracts for JSE-listed companies and private corporations.'
        },
        {
          num:'II',
          title:'Dispute Resolution & Litigation',
          body:'Complex commercial litigation, arbitration and mediation across South Africa\'s high courts. We have an unparalleled record in Johannesburg\'s Commercial Court.'
        },
        {
          num:'III',
          title:'Property & Conveyancing',
          body:'High-value property transactions, commercial real estate acquisitions, development agreements and conveyancing for Sandton\'s most significant property portfolios.'
        },
        {
          num:'IV',
          title:'Employment & Labour Law',
          body:'Executive employment contracts, restraint of trade disputes, CCMA representation and workforce restructuring for South Africa\'s leading employers.'
        },
        {
          num:'V',
          title:'Estate Planning & Trusts',
          body:'Wills, trusts, estate administration and succession planning for high-net-worth individuals and multi-generational family wealth structures.'
        },
        {
          num:'VI',
          title:'Tax Law & Advisory',
          body:'Corporate tax structuring, SARS disputes, international tax planning and VAT advisory for businesses operating across South Africa and Sub-Saharan Africa.'
        }
      ].map((item, i) => (
        <div class="accordion-item" data-index={i} style="border-bottom:1px solid var(--border-subtle);">
          <button
            class="accordion-trigger w-full flex items-center justify-between py-6 px-2 group"
            aria-expanded="false"
            style="background:transparent;border:none;cursor:pointer;text-align:left;"
          >
            <span class="font-playfair text-xl font-light w-12 shrink-0" style="color:var(--gold);opacity:0.55;">{item.num}</span>
            <span class="font-playfair text-white text-xl font-semibold flex-1 mx-6 group-hover:text-yellow-400 transition-colors duration-300">{item.title}</span>
            <span class="accordion-icon font-inter text-2xl font-thin transition-transform duration-400 shrink-0" style="color:var(--gold);line-height:1;">+</span>
          </button>
          <div class="accordion-body overflow-hidden" style="max-height:0;transition:max-height 0.5s cubic-bezier(0.4,0,0.2,1);">
            <div style="padding:0 2rem 1.75rem 3.5rem;border-left:2px solid var(--gold);margin:0 0.5rem 1.5rem 3rem;">
              <p class="font-inter text-sm leading-relaxed" style="color:#888;font-weight:300;">{item.body}</p>
            </div>
          </div>
          <!-- Thin gold line top on first item -->
          {i === 0 && <div style="position:absolute;top:0;left:0;right:0;height:1px;background:rgba(201,151,43,0.3);"></div>}
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     MARBLE QUOTE — FULL VIEWPORT
═══════════════════════════════════════════════ -->
<section class="marble-bg relative" style="min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:6rem 2rem;">
  <!-- Massive watermark quote mark -->
  <div aria-hidden="true" style="
    position:absolute;
    top:50%;left:50%;
    transform:translate(-55%,-60%);
    font-family:'Playfair Display',serif;
    font-size:400px;
    line-height:1;
    color:var(--gold);
    opacity:0.08;
    pointer-events:none;
    user-select:none;
    z-index:0;
  ">&ldquo;</div>

  <div class="relative max-w-4xl mx-auto fade-up" style="z-index:1;">
    <blockquote class="font-playfair italic text-center" style="font-size:clamp(1.6rem,3.5vw,3rem);color:#1C1A18;line-height:1.5;font-weight:500;">
      The law is not a profession for those who seek comfort. It is a calling for those who seek truth.
    </blockquote>
  </div>

  <!-- Attribution bottom right -->
  <div class="absolute bottom-12 right-12 text-right fade-up delay-2" style="z-index:1;">
    <div style="width:48px;height:1px;background:var(--gold);margin-left:auto;margin-bottom:0.75rem;"></div>
    <p class="font-inter font-medium tracking-[0.2em] uppercase text-xs" style="color:#8A6B1A;">Jonathan Sterling</p>
    <p class="font-inter text-xs mt-0.5" style="color:#9A7A2A;letter-spacing:0.1em;">Founding Partner</p>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     TEAM — ASYMMETRIC EDITORIAL
═══════════════════════════════════════════════ -->
<section id="team" style="background:var(--bg-secondary);padding:6rem 2rem;">
  <div class="max-w-screen-xl mx-auto">
    <div class="text-center mb-14">
      <span class="section-label fade-up">Our Attorneys</span>
      <h2 class="font-playfair text-white fade-up delay-1" style="font-size:clamp(2rem,4vw,3rem);font-weight:700;">
        The Minds Behind Sterling
      </h2>
      <span class="gold-underline fade-up delay-1"></span>
    </div>

    <div class="flex flex-col lg:flex-row gap-0" style="border:1px solid var(--border-subtle);">

      <!-- Left: Senior Partner dominant -->
      <div class="flex-1 lg:w-1/2 flex flex-col items-center justify-center p-10 lg:p-16 fade-up delay-1" style="border-right:1px solid rgba(201,151,43,0.3);border-bottom:1px solid var(--border-subtle);">
        <!-- Large portrait placeholder -->
        <div class="flex items-center justify-center mb-8" style="width:140px;height:140px;border:1px solid var(--gold);background:#0F0F0F;">
          <span class="font-playfair text-4xl font-semibold" style="color:var(--gold);">JS</span>
        </div>
        <!-- Massive name -->
        <h3 class="font-playfair text-white text-center font-bold mb-3" style="font-size:clamp(2.2rem,4vw,4rem);line-height:1.1;">
          Jonathan<br/>Sterling
        </h3>
        <p class="font-inter text-xs tracking-widest uppercase mb-3" style="color:var(--gold);">Senior Partner — 37 Years</p>
        <p class="font-inter text-xs" style="color:#555;">Corporate Law · Dispute Resolution</p>
        <div style="width:48px;height:1px;background:var(--gold);margin-top:1.5rem;opacity:0.5;"></div>
      </div>

      <!-- Right: Three associates stacked -->
      <div class="flex-1 lg:w-1/2 flex flex-col">
        {[
          { initials:'MC', name:'Margaret Chen',    title:'Partner — 18 Years',    spec:'Property Law · Conveyancing' },
          { initials:'DR', name:'David Rasmussen',  title:'Partner — 12 Years',    spec:'Employment Law · Labour Relations' },
          { initials:'NP', name:'Naledi Phiri',     title:'Associate — 6 Years',   spec:'Tax Law · Estate Planning' },
        ].map((a, i) => (
          <div class={`flex items-center gap-6 p-8 fade-up delay-${i+2}`} style={i < 2 ? 'border-bottom:1px solid var(--border-subtle);' : ''}>
            <div class="flex items-center justify-center shrink-0" style="width:64px;height:64px;border:1px solid rgba(201,151,43,0.45);background:#0F0F0F;">
              <span class="font-playfair text-xl font-semibold" style="color:var(--gold);">{a.initials}</span>
            </div>
            <div>
              <h4 class="font-playfair text-white text-xl font-semibold mb-1">{a.name}</h4>
              <p class="font-inter text-xs tracking-widest uppercase mb-1" style="color:var(--gold);">{a.title}</p>
              <p class="font-inter text-xs" style="color:#555;">{a.spec}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════
     RESULTS — OVERSIZED TYPOGRAPHIC
═══════════════════════════════════════════════ -->
<!-- ═══════════════════════════════════════════════
     RESULTS — BENTO GRID + CINEMATIC STATS
═══════════════════════════════════════════════ -->
<section id="results" style="background:var(--bg-primary);padding:6rem 2rem 0;">
  <div class="max-w-screen-xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-14 gap-4">
      <div>
        <span class="section-label fade-up">Track Record</span>
        <h2 class="font-playfair text-white fade-up delay-1" style="font-size:clamp(2rem,4vw,3rem);font-weight:700;line-height:1.15;margin-top:0.5rem;">
          Results That Speak<br/>for Themselves
        </h2>
        <span class="gold-underline fade-up delay-1" style="margin-left:0;"></span>
      </div>
      <p class="font-inter fade-up delay-2" style="color:#555;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;max-width:240px;line-height:1.7;text-align:right;">
        Johannesburg's most trusted<br/>corporate law practice
      </p>
    </div>
  </div>

  <!-- BENTO GRID — full bleed -->
  <div class="results-bento">

    <!-- Cell A: 1,200+ large — dark gold tinted -->
    <div class="bento-cell bento-a fade-up delay-1" style="background:#0E0B05;border:1px solid rgba(201,151,43,0.12);padding:3rem 3.5rem;display:flex;flex-direction:column;justify-content:flex-end;position:relative;overflow:hidden;min-height:320px;">
      <!-- Faint watermark numeral -->
      <div aria-hidden="true" style="position:absolute;bottom:-0.5rem;right:-1rem;font-family:'Playfair Display',serif;font-size:14rem;font-weight:800;color:rgba(201,151,43,0.06);line-height:1;pointer-events:none;user-select:none;">1,200</div>
      <div class="font-inter text-xs tracking-widest uppercase mb-4" style="color:rgba(201,151,43,0.5);">Cases Handled</div>
      <div class="font-playfair font-bold" style="font-size:clamp(4rem,9vw,7.5rem);color:var(--gold);line-height:0.88;letter-spacing:-0.02em;">
